#!/usr/bin/env bash
set -e

if [ "$EUID" -ne 0 ]; then
    echo "ERROR: This backend must run as root." >&2
    exit 1
fi

BACKUP_FILE="/tmp/torsurf_nft_backup.nft"

case "$1" in
    start)
        nft list ruleset > "$BACKUP_FILE" 2>/dev/null || true

        systemctl start tor

        sleep 2
        if ! ss -tlnp | grep -q :9040; then
            echo "ERROR: Tor TransPort (9040) is not listening. Check systemctl status tor" >&2
            exit 1
        fi

        cat <<EOF > /tmp/torsurf_rules.nft
table inet torsurf {
    chain output {
        type filter hook output priority filter; policy drop;

        # Allow localhost traffic
        oifname "lo" accept

        # Crucial Fix: Fedora uses the "tor" user, not "toranon"
        meta skuid "tor" accept

        # Intercept and route DNS traffic directly to Tor's DNSPort
        udp dport 53 redirect to :5353
        tcp dport 53 redirect to :5353

        # Force all remaining IPv4 TCP traffic through Tor's TransPort
        meta nfproto ipv4 meta l4proto tcp redirect to :9040

        # Drop everything else (Blocks raw UDP, ICMP, and all IPv6 leaks)
        drop
    }
}
EOF
        # Load and clean up tracking configuration files
        nft -f /tmp/torsurf_rules.nft
        rm -f /tmp/torsurf_rules.nft
        echo "SUCCESS"
        ;;

    stop)
        # Drop the dual-stack isolation rules table
        nft delete table inet torsurf 2>/dev/null || true

        if [ -f "$BACKUP_FILE" ]; then
            nft flush ruleset
            nft -f "$BACKUP_FILE" 2>/dev/null || true
            rm -f "$BACKUP_FILE"
        fi

        systemctl stop tor
        echo "SUCCESS"
        ;;

    status)
        if nft list table inet torsurf &>/dev/null; then
            echo "ACTIVE"
            exit 0
        else
            echo "INACTIVE"
            exit 1
        fi
        ;;
    *)
        echo "Usage: $0 {start|stop|status}"
        exit 1
        ;;
esac