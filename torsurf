#!/usr/bin/env bash

# Terminal Escape Colors
RESET="\e[0m"
BOLD="\e[1m"
GREEN="\e[32m"
RED="\e[31m"
YELLOW="\e[33m"
CYAN="\e[36m"
MAGENTA="\e[35m"
WHITE_ON_PURPLE="\e[1;37;45m"
DIM="\e[2m"

declare -a HISTORY=()
MAX_HISTORY=50
for i in $(seq 1 $MAX_HISTORY); do HISTORY+=(0); done

BACKEND="/usr/local/bin/torsurf-core"

get_network_bytes() {
    local rx tx total
    total=0
    while read -r line; do
        if [[ "$line" =~ : ]] && [[ ! "$line" =~ lo: ]]; then
            rx=$(echo "$line" | awk '{print $2}')
            tx=$(echo "$line" | awk '{print $10}')
            total=$((total + rx + tx))
        fi
    done < /proc/net/dev
    echo "$total"
}

get_tor_ip() {
    local ip
    ip=$(curl -s --connect-timeout 5 https://check.torproject.org/api/ip | jq -r '.IP' 2>/dev/null)
    if [[ -z "$ip" || "$ip" == "null" ]]; then
        echo "Protected / Fetching IP..."
    else
        echo "$ip"
    fi
}

draw_graph() {
    local max=1
    for val in "${HISTORY[@]}"; do
        if (( $(echo "$val > $max" | bc -l) )); then
            max=$val
        fi
    done

    local blocks=(" " " " "▂" "▃" "▄" "▅" "▆" "▇" "█")
    
    local term_cols=$(tput cols 2>/dev/null || echo 80)
    local graph_width=$((term_cols - 12))
    if [ $graph_width -gt $MAX_HISTORY ]; then
        graph_width=$MAX_HISTORY
    fi

    local start_idx=$((${#HISTORY[@]} - graph_width))
    local display_history=("${HISTORY[@]:$start_idx}")

    echo -e "${BOLD}${WHITE_ON_PURPLE}  BANDWIDTH MONITOR  ${RESET}"
    echo -n -e "  ${DIM}📈 [${RESET}"
    for val in "${display_history[@]}"; do
        local idx=$(echo "scale=0; ($val * 8) / $max" | bc 2>/dev/null || echo 0)
        if [ "$idx" -gt 8 ]; then idx=8; fi
        if [ "$idx" -lt 0 ]; then idx=0; fi
        
        # Color code the graph bars based on intensity
        if (( $(echo "$val > ($max * 0.7)" | bc -l) )); then
            echo -n -e "${RED}${blocks[$idx]}${RESET}"
        elif (( $(echo "$val > ($max * 0.3)" | bc -l) )); then
            echo -n -e "${YELLOW}${blocks[$idx]}${RESET}"
        else
            echo -n -e "${GREEN}${blocks[$idx]}${RESET}"
        fi
    done
    echo -e "${DIM}]${RESET}"
    printf "  ${DIM}Current:${RESET} %-8.2f KB/s  |  ${DIM}Peak Session Volume:${RESET} %.2f KB/s\n" "${HISTORY[-1]}" "$max"
}

render_dashboard() {
    local ip="$1"
    local speed="$2"
    
    tput civis
    tput cup 0 0
    
    echo -e "${CYAN}┏━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━┓${RESET}"
    echo -e "${CYAN}┃${RESET}                   ${BOLD}${GREEN}⚡ TORSURF ANONYMITY CONSOLE ⚡${RESET}                    ${CYAN}┃${RESET}"
    echo -e "${CYAN}┗━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━┛${RESET}"
    echo -e "  ${BOLD}STATUS:${RESET}             ${GREEN}● Connected & Routing Securely${RESET}"
    echo -e "  ${BOLD}TUNNEL GATEWAY:${RESET}     ${CYAN}TransPort (9040)${RESET} -> ${CYAN}DNSPort (9053)${RESET}"
    echo -e "  ${BOLD}VIRTUAL EXIT IP:${RESET}    ${WHITE_ON_PURPLE} $ip ${RESET}"
    echo -e "${CYAN}───────────────────────────────────────────────────────────────────────${RESET}"
    
    draw_graph
    
    echo -e "${CYAN}───────────────────────────────────────────────────────────────────────${RESET}"
    echo -e "  ${DIM}Press [Ctrl+C] to exit monitor view. Tunnel will remain active.${RESET}"
}

cleanup() {
    tput cnorm # Restore terminal cursor visibility
    echo -e "\n\n${YELLOW}[!] Detached from dashboard monitor view.${RESET}"
    echo -e "${CYAN}[*] Your background Tor tunnel remains ACTIVE.${RESET}"
    echo -e "${CYAN}[*] Run 'torsurf stop' to restore clear internet routing.${RESET}"
    exit 0
}

case "${1,,}" in
    start)
        if sudo "$BACKEND" status &>/dev/null; then
            echo -e "${YELLOW}[!] TorSurf routing is already active.${RESET}"
            exit 0
        fi

        echo -e "${YELLOW}[*] Initializing Tor daemon and loading isolated firewall tables...${RESET}"
        
        # Execute backend and capture any diagnostic errors explicitly
        BACKEND_RUN=$(sudo "$BACKEND" start 2>&1)
        if [[ "$BACKEND_RUN" != *"SUCCESS"* ]]; then
            echo -e "${RED}✘ Operational Fault: Core initialization pipeline failed.${RESET}"
            echo -e "${RED}═════════════════════════════════════════════════════════════${RESET}"
            echo -e "${YELLOW}Backend Engine Output:${RESET}"
            echo "$BACKEND_RUN"
            echo -e "${RED}═════════════════════════════════════════════════════════════${RESET}"
            exit 1
        fi

        echo -e "${GREEN}✔ Secure routing environment established successfully.${RESET}"
        echo -e "${YELLOW}[*] Performing cryptographic exit-node context handshake...${RESET}"
        
        TOR_IP=$(get_tor_ip)
        LAST_BYTES=$(get_network_bytes)
        
        clear
        trap cleanup INT
        
        while true; do
            if [[ "$TOR_IP" == *"Fetching"* || "$TOR_IP" == "Isolated" ]]; then
                TOR_IP=$(get_tor_ip)
            fi

            CURRENT_BYTES=$(get_network_bytes)
            BYTES_DELTA=$((CURRENT_BYTES - LAST_BYTES))
            LAST_BYTES=$CURRENT_BYTES
            
            KB_SPEED=$(echo "scale=2; $BYTES_DELTA / 1024.0" | bc)
            
            HISTORY=("${HISTORY[@]:1}" "$KB_SPEED")
            
            render_dashboard "$TOR_IP" "$KB_SPEED"
            sleep 1
        done
        ;;
        
    stop)
        if ! sudo "$BACKEND" status &>/dev/null; then
            echo -e "${YELLOW}[!] TorSurf is already inactive. Clearnet active.${RESET}"
            exit 0
        fi

        echo -n -e "${YELLOW}[*] Tearing down firewall filters and stopping Tor... ${RESET}"
        BACKEND_STOP=$(sudo "$BACKEND" stop 2>&1)
        if [[ "$BACKEND_STOP" == *"SUCCESS"* ]]; then
            echo -e "${GREEN}✔ Clearnet restored configuration successfully.${RESET}"
        else
            echo -e "${RED}✘ Error restoring ruleset.${RESET}"
            echo "$BACKEND_STOP"
        fi
        ;;
        
    status)
        if sudo "$BACKEND" status &>/dev/null; then
            echo -e "${GREEN}● TorSurf STATUS: ACTIVE (Your traffic is anonymized)${RESET}"
        else
            echo -e "${RED}○ TorSurf STATUS: INACTIVE (Clearnet interface active)${RESET}"
        fi
        ;;
        
    *)
        echo -e "${RED}Usage:${RESET} torsurf {start|stop|status}"
        exit 1
        ;;
esac